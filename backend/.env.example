# Backend Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT COMMIT .env file to version control

# Server
PORT=3000
NODE_ENV=production

# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/furnistore

# JWT Secret (use a strong, random string - minimum 32 characters)
JWT_SECRET=your-super-secret-jwt-key-here-make-it-very-long-and-random

# CORS Settings
CORS_ORIGIN=http://localhost:3003

# Email Configuration (optional, for forgot password)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Admin User (optional, for seeding)
ADMIN_EMAIL=admin@furnistore.com
ADMIN_PASSWORD=your-admin-password
